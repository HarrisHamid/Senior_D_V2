# Copy this file to .env and fill in the values before running docker compose up

# Required
JWT_SECRET=                        # generate with: openssl rand -hex 32

# Email (set to "resend" in production)
EMAIL_PROVIDER=resend
RESEND_API_KEY=                    # from resend.com dashboard
EMAIL_FROM=noreply@sdm.cs.stevens.edu

# Your site's public URL
CORS_ORIGIN=https://sdm.cs.stevens.edu
FRONTEND_URL=https://sdm.cs.stevens.edu

# Optional — defaults shown
# JWT_EXPIRE=7d
# JWT_COOKIE_EXPIRE=7
